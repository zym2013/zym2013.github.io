---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  toc: any[];
  content: string;
  pageTitle?: string;
  allPosts?: Array<{ slug: string; title: string }>;
}

const {
  title,
  description,
  pubDate,
  tags = [],
  toc,
  content,
  pageTitle = title,
  isHome = false,
  allPosts = [],
} = Astro.props;
---

<Layout title={`${title} - zym2013`} description={description} isHome={false}>
  <div class="center-wrap project-layout">
    <main class="page-card blog-main-container">
      <!-- 移动端目录触发按钮 -->
      {
        toc && toc.length > 0 && (
          <button
            id="toc-toggle-btn"
            class="mobile-toc-btn"
            aria-label="打开目录"
          >
            <i class="fa-solid fa-list-ul" />
          </button>
        )
      }

      <div class="blog-grid">
        <!-- 左侧/主内容区 -->
        <article class="blog-content">
          <header class="article-header">
            <h1 class="article-title">{title}</h1>
            <div class="article-meta">
              <span
                ><i class="fa-regular fa-calendar"></i>
                {pubDate.toLocaleDateString("zh-CN")}</span
              >
              {
                tags.length > 0 && (
                  <span>
                    <i class="fa-solid fa-tags" /> {tags.join(", ")}
                  </span>
                )
              }
            </div>
          </header>

          <!-- 正文 -->
          <div class="markdown-body" set:html={content} />

          <div class="d-flex justify-content-start mb-3 mt-4">
            <a href="/blog/" class="back-link">
              <i class="fa-solid fa-arrow-left"></i> 返回博客列表
            </a>
          </div>
        </article>

        <!-- 宽屏目录 (右侧固定) -->
        {
          toc && toc.length > 0 && (
            <aside class="desktop-toc">
              <div class="toc-inner">
                <h3>
                  <i class="fa-solid fa-bookmark" /> 目录
                </h3>
                <ul>
                  {toc.map((item) => (
                    <li style={`margin-left: ${(item.depth - 2) * 12}px`}>
                      <a href={`#${item.slug}`}>{item.text}</a>
                    </li>
                  ))}
                </ul>
              </div>
            </aside>
          )
        }
      </div>
    </main>
  </div>

  <!-- 窄屏目录抽屉 (左侧滑出) -->
  {
    toc && toc.length > 0 && (
      <>
        <div id="toc-overlay" class="toc-overlay" />
        <aside id="mobile-toc-drawer" class="mobile-toc-drawer">
          <div class="drawer-header">
            <h3>目录</h3>
            <button id="toc-close-btn" aria-label="关闭目录">
              <i class="fa-solid fa-xmark" />
            </button>
          </div>
          <div class="drawer-content">
            <ul>
              {toc.map((item) => (
                <li style={`margin-left: ${(item.depth - 2) * 12}px`}>
                  <a href={`#${item.slug}`} class="mobile-toc-link">
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </>
    )
  }
</Layout>

<style>
  .blog-main-container {
    max-width: 1200px;
    padding: 0;
    border: none;
    box-shadow: none;
    background: transparent;
    position: relative;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .blog-content {
    padding: 2rem;
    overflow-x: hidden;
    min-height: 50vh;
  }
  @keyframes slide-in {
    from {
      transform: translateX(100%);
    }

    to {
      transform: translateX(0);
    }
  }
  .mobile-toc-btn {
    animation: forwards slide-in 0.7s ease-out;
  }
  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: 1fr 280px;
      align-items: start;
    }
    .desktop-toc {
      position: sticky;
      top: 6rem;
      max-height: calc(100vh - 4rem);
      overflow-y: auto;
      background: var(--background);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
    }
    .desktop-toc h3 {
      font-size: 1rem;
      margin-bottom: 1rem;
      color: var(--foreground);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .mobile-toc-btn,
    .toc-overlay,
    .mobile-toc-drawer {
      display: none !important;
    }
  }
  @media (max-width: 1023px) {
    .desktop-toc {
      display: none;
    }
    .mobile-toc-btn {
      position: fixed;
      right: 0;
      top: 25%;
      transform: translateY(-50%);
      width: 40px;
      height: 40px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 8px 0 0 8px;
      cursor: pointer;
      z-index: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      box-shadow: 2px 0 8px rgba(0, 0, 0, 0.2);
      transition: background 0.3s;
    }
    .mobile-toc-btn:hover {
      background: var(--link-hover);
    }
    .toc-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.2);
      z-index: 998;
      opacity: 0;
      visibility: hidden;
      transition:
        opacity 0.3s,
        visibility 0.3s;
      backdrop-filter: blur(2px);
    }
    .toc-overlay.active {
      opacity: 1;
      visibility: visible;
    }
    .mobile-toc-drawer {
      position: fixed;
      top: 100px;
      left: 0;
      width: 280px;
      height: 100%;
      background: var(--background-2);
      z-index: 999;
      transform: translateX(-100%);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
      display: flex;
      flex-direction: column;
      border-right: 1px solid var(--border);
      border-radius: 0 20px 20px 0;
      height: calc(100% - 12rem);
      backdrop-filter: blur(6px);
    }
    .mobile-toc-drawer.active {
      transform: translateX(0);
    }
    .drawer-header {
      padding: 1rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .drawer-header h3 {
      margin: 0;
      font-size: 1.1rem;
      color: var(--foreground);
    }
    .drawer-header button {
      display: none;
      background: none;
      border: none;
      font-size: 1.2rem;
      color: var(--foreground);
      cursor: pointer;
      padding: 0.5rem;
    }
    .drawer-content {
      flex: 1;
      overflow-y: auto;
      padding: 1rem;
    }
  }
  .toc-inner ul,
  .drawer-content ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-inner li,
  .drawer-content li {
    margin-bottom: 0.5rem;
  }
  .toc-inner a,
  .mobile-toc-link {
    display: block;
    font-size: 0.9rem;
    color: var(--foreground);
    text-decoration: none;
    padding: 0.2rem 0;
    transition: color 0.2s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .toc-inner a:hover,
  .mobile-toc-link:hover,
  .toc-inner a.active,
  .mobile-toc-link.active {
    color: var(--accent);
  }
  .article-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 1rem;
    margin-bottom: 2rem;
  }
  .article-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--foreground);
  }
  .article-meta {
    font-size: 0.9rem;
    color: var(--foreground);
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .back-link {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }
  .back-link:hover {
    text-decoration: underline;
  }
  .markdown-body {
    line-height: 1.7;
    color: var(--foreground);
  }
  .markdown-body h1,
  .markdown-body h2,
  .markdown-body h3 {
    margin-bottom: 0.5em;
    font-weight: 600;
    color: var(--foreground);
  }
  .markdown-body h1 {
    font-size: 1.8em;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.3em;
  }
  .markdown-body h2 {
    font-size: 1.5em;
  }
  .markdown-body h3 {
    font-size: 1.25em;
  }
  .markdown-body p {
    margin-bottom: 1em;
  }
  .markdown-body a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px dashed var(--accent);
  }
  .markdown-body :not(pre) > code {
    background: var(--muted);
    padding: 0.2em 0.4em;
    border-radius: 3px;
  }
  @media (max-width: 768px) {
    .mobile-toc-drawer {
      top: 100px !important;
    }
  }
</style>

<script>
  if (typeof document !== "undefined") {
    const toggleBtn = document.getElementById("toc-toggle-btn");
    const closeBtn = document.getElementById("toc-close-btn");
    const drawer = document.getElementById("mobile-toc-drawer");
    const overlay = document.getElementById("toc-overlay");
    const mobileLinks = document.querySelectorAll(".mobile-toc-link");

    function openDrawer() {
      drawer?.classList.add("active");
      overlay?.classList.add("active");
      document.body.style.overflow = "hidden";
    }

    function closeDrawer() {
      drawer?.classList.remove("active");
      overlay?.classList.remove("active");
      document.body.style.overflow = "";
    }

    toggleBtn?.addEventListener("click", openDrawer);
    closeBtn?.addEventListener("click", closeDrawer);
    overlay?.addEventListener("click", closeDrawer);

    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        closeDrawer();
      });
    });
  }
</script>
