---
import Layout from "./Layout.astro";

interface Props {
	title: string;
	description: string;

	// 日期兼容：支持多种字段名
	pubDate?: Date | string;
	createdAt?: Date | string;
	updatedAt?: Date | string;

	tags?: string[];
	toc?: any[]; // 目录数据

	content: string; // 渲染后的 HTML

	pageTitle?: string;
	allPosts?: Array<{ slug: string; title: string }>; // 用于随机跳转

	// 自定义返回链接文本和路径
	backLinkText?: string;
	backLinkHref?: string;
}

const {
	title,
	description,
	pubDate,
	createdAt,
	updatedAt,
	tags = [],
	toc = [],
	content,
	pageTitle = title,
	allPosts = [],
	backLinkText,
	backLinkHref,
} = Astro.props;

// 1. 确定显示日期 (优先 pubDate -> updatedAt -> createdAt)
const dateObj = pubDate
	? new Date(pubDate)
	: updatedAt
		? new Date(updatedAt)
		: createdAt
			? new Date(createdAt)
			: null;
const displayDateStr = dateObj ? dateObj.toLocaleDateString("zh-CN") : "";

// 2. 确定返回链接 (如果未指定，尝试根据标题推断，默认回博客)
const finalBackText =
	backLinkText ||
	(title.includes("实验室") || pageTitle.includes("实验")
		? "返回实验室列表"
		: "返回博客列表");
const finalBackHref =
	backLinkHref || (finalBackText.includes("实验室") ? "/lab/" : "/blog/");

// 3. 判断是否有目录，以决定布局模式
const hasToc = toc && toc.length > 0;
---

<Layout
	title={`${title} - zym2013`}
	description={description}
	isHome={false}
	pageTitle={pageTitle}
	allPosts={allPosts}
>
	<div class="center-wrap markdown-layout-container">
		<main
			class="page-card markdown-main-wrapper"
			class:list={{ "no-toc": !hasToc }}
		>
			<!-- 移动端目录触发按钮 (仅当有目录时显示) -->
			{
				hasToc && (
					<button
						id="toc-toggle-btn"
						class="mobile-toc-btn"
						aria-label="打开目录"
					>
						<i class="fa-solid fa-list-ul" />
					</button>
				)
			}

			<div class="markdown-grid">
				<!-- 左侧/主内容区 -->
				<article class="markdown-content">
					<header class="article-header">
						<h1 class="article-title">{title}</h1>

						<div class="article-meta">
							{
								displayDateStr && (
									<span class="meta-item">
										<i class="fa-regular fa-calendar" />{" "}
										{displayDateStr}
									</span>
								)
							}

							{
								tags.length > 0 && (
									<span class="meta-item">
										<i class="fa-solid fa-tags" />{" "}
										{tags.join(", ")}
									</span>
								)
							}
						</div>
					</header>

					<!-- 正文内容 -->
					<div class="markdown-body" set:html={content} />

					<!-- 底部返回链接 -->
					<div class="back-nav-container">
						<a href={finalBackHref} class="back-link">
							<i class="fa-solid fa-arrow-left"></i>
							{finalBackText}
						</a>
					</div>
				</article>

				<!-- 宽屏目录 (右侧固定) -->
				{
					hasToc && (
						<aside class="desktop-toc">
							<div class="toc-inner">
								<h3>
									<i class="fa-solid fa-bookmark" /> 目录
								</h3>
								<ul>
									{toc.map((item) => (
										<li
											style={`margin-left: ${(item.depth - 2) * 12}px`}
										>
											<a href={`#${item.slug}`}>
												{item.text}
											</a>
										</li>
									))}
								</ul>
							</div>
						</aside>
					)
				}
			</div>
		</main>

		<!-- 窄屏目录抽屉 (左侧滑出) -->
		{
			hasToc && (
				<>
					<div id="toc-overlay" class="toc-overlay" />
					<aside id="mobile-toc-drawer" class="mobile-toc-drawer">
						<div class="drawer-header">
							<h3>目录</h3>
							<button id="toc-close-btn" aria-label="关闭目录">
								<i class="fa-solid fa-xmark" />
							</button>
						</div>
						<div class="drawer-content">
							<ul>
								{toc.map((item) => (
									<li
										style={`margin-left: ${(item.depth - 2) * 12}px`}
									>
										<a
											href={`#${item.slug}`}
											class="mobile-toc-link"
										>
											{item.text}
										</a>
									</li>
								))}
							</ul>
						</div>
					</aside>
				</>
			)
		}
	</div>

	<style>
		.markdown-grid {
			margin-top: 30px;
		}
	</style>

	<script>
		if (typeof document !== "undefined") {
			const toggleBtn = document.getElementById("toc-toggle-btn");
			const closeBtn = document.getElementById("toc-close-btn");
			const drawer = document.getElementById("mobile-toc-drawer");
			const overlay = document.getElementById("toc-overlay");
			const mobileLinks = document.querySelectorAll(".mobile-toc-link");

			function openDrawer() {
				drawer?.classList.add("active");
				overlay?.classList.add("active");
				document.body.style.overflow = "hidden";
			}

			function closeDrawer() {
				drawer?.classList.remove("active");
				overlay?.classList.remove("active");
				document.body.style.overflow = "";
			}

			toggleBtn?.addEventListener("click", openDrawer);
			closeBtn?.addEventListener("click", closeDrawer);
			overlay?.addEventListener("click", closeDrawer);

			mobileLinks.forEach((link) => {
				link.addEventListener("click", () => closeDrawer());
			});
		}
	</script>
</Layout>
