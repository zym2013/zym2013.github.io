---
// src/components/PostCard.astro
import { parseColor } from "../lib/color";
import StatusBadge from "./StatusBadge.vue";
interface Props {
  slug: string;
  title: string;
  excerpt: string;
  pubDate: Date | string;
  wordCount?: number;
  readingTime?: string;
  tags: string[];
  icon?: string;
  iconColor?: string;
  category?: string;
  categoryColor?: string;
  delay?: number;
  statusConfig?: Array<{ text: string; icon: string }>;
}
const {
  slug,
  title,
  excerpt,
  pubDate,
  wordCount,
  readingTime,
  tags,
  icon = "fa-solid fa-feather-pointed",
  iconColor,
  category = "未分类",
  categoryColor,
  delay = 0,
  statusConfig
} = Astro.props;
const finalIconColor = parseColor(iconColor, "#64748b");
const finalCategoryColor = parseColor(categoryColor, "#64748b");
const formatDate = (date: Date | string): string => {
  const d = new Date(date);
  return d
    .toLocaleDateString("zh-CN", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
    })
    .replace(/\//g, "-");
};
---

<a href={`/blog/${slug}/`} class="post-card" style={`--delay: ${delay}ms`}>
  <div class="card-content">
    {statusConfig?.length > 0 && (
      <div class="card-statuses">
        {statusConfig.map((status, i) => (
          <StatusBadge 
            client:only="vue" 
            status={status} 
            :key={`status-${i}`}
          />
        ))}
      </div>
    )}
    
    <div class="card-meta">
      <span class="date">{formatDate(pubDate)}</span>
      <span class="separator">·</span>
      <span class="read-time">{(wordCount ? `${wordCount} 字` : '')}</span>
      <span class="separator">·</span>
      <span class="read-time">{readingTime}</span>
    </div>
    
    <div class="card-title-container">
      <h3 class="card-title">{title}</h3>
      <p class="card-excerpt">{excerpt}</p>
    </div>
    
    <div class="card-tags">
      <span class="category" style={`color: ${finalCategoryColor}`}>{category}</span>
      {tags.map((tag) => {
        const tagName = tag.startsWith("#") ? tag : `#${tag}`;
        return <span class="tag">{tagName}</span>;
      })}
    </div>
  </div>
  
  <div class="card-icon" style={`--icon-color: ${finalIconColor}`}>
    <i class={icon}></i>
  </div>
</a>

<style>
  @keyframes slide-in {
    from {
      transform: translateY(-100%);
    }

    to {
      transform: translateY(0);
    }
  }
  @keyframes slide-in-2 {
    from {
      transform: translateY(100%);
    }

    to {
      transform: translateY(0);
    }
  }
  @keyframes slide-in-3 {
    from {
      transform: translateX(-100%);
    }

    to {
      transform: translateX(0);
    }
  }

  .card-title-container {
    overflow: hidden;
  }

  .card-title {
    animation: slide-in-3 .7s forwards;
  }

  .card-meta
  {
    animation: slide-in 1s forwards;
  }

  .card-excerpt{
    animation: slide-in-2 .7s forwards;
  } .card-tags {
    animation: slide-in-2 1s forwards;
  }

  /* 🔥 状态徽章容器：竖向排列 + 右侧吸附 */
  .card-statuses {
  overflow: hidden;
    position: absolute;
    top: 0rem;
    right: -1.5rem;
    z-index: 3;  /* 🔥 最高层级，确保不被遮挡 */
    display: flex;
    flex-direction: column;  /* 🔥 竖向排列 */
    align-items: flex-end;   /* 🔥 右对齐 */
    gap: 0.5rem;  /* 🔥 徽章间距 */
    pointer-events: none;  /* 🔥 容器不拦截点击，让内部按钮可交互 */
  }
  
  /* 🔥 确保徽章按钮可交互 */
  .card-statuses > * {
    pointer-events: auto;
  }

  /* 🔥 移动端适配：徽章默认展开 */
  @media (max-width: 768px) {
    .card-statuses {
      top: -0.5rem;
      right: -1.3rem;
    }
  }
  
  /* 🔥 卡片基础样式 */
  .post-card {
    position: relative;  /* 🔥 为绝对定位子元素提供参照 */
    display: block;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--foreground);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    overflow: visible;  /* 🔥 允许徽章展开时溢出 */
    opacity: 0;
    transform: translateY(20px);
    animation: card-fade-in 0.6s ease forwards;
    animation-delay: var(--delay, 0ms);
  }
  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    border-color: var(--accent);
  }
  .post-card:hover .card-icon i,
  .post-card:active .card-icon i {
    transform: rotate(-18deg) scale(1.15);
  }
  .card-content {
    position: relative;
    z-index: 1;
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--vp-c-text-3);
    margin-bottom: 0.8rem;
  }
  .separator {
    color: var(--border);
  }
  .card-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.6rem;
    color: var(--foreground);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-excerpt {
    font-size: 0.95rem;
    color: var(--vp-c-text-2);
    margin: 0 3rem 1rem 0;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
  }
  .category {
    font-weight: 500;
    color: var(--foreground);
  }
  .tag {
    color: var(--vp-c-text-2);
    transition: color 0.2s ease;
  }
  .post-card:hover .tag {
    color: var(--accent);
  }
  .card-icon {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    z-index: 0;
    width: 80px;
    height: 80px;
    opacity: 0;
    filter: blur(8px);
    animation: icon-fade-in 0.8s ease forwards;
    animation-delay: calc(var(--delay, 0ms) + 200ms);
  }
  .card-icon i {
    font-size: 4rem;
    color: var(--icon-color, var(--vp-c-text-3));
    transform: rotate(-10deg);
    transition: transform 0.3s ease;
  }
  @keyframes card-fade-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes icon-fade-in {
    to {
      opacity: 1;
      filter: blur(0);
    }
  }
  @media (max-width: 768px) {
    .post-card {
      padding: 1.2rem;
    }
    .card-title {
      font-size: 1.1rem;
    }
    .card-excerpt {
      font-size: 0.9rem;
      -webkit-line-clamp: 2;
    }
    .card-tags {
      gap: 0.3rem;
      font-size: 0.8rem;
    }
  }
  html[data-theme="dark"] .post-card {
    background: var(--background);
    border-color: var(--border);
  }
  html[data-theme="dark"] .post-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }
</style>
