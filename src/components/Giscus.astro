---
// src/components/Giscus.astro
interface Props {
  category?: string;
  categoryId?: string;
  repo?: string;        // 可选：允许覆盖默认仓库
  repoId?: string;      // 可选：允许覆盖默认 ID
  mapping?: string;     // 可选：映射方式
}

const { 
  category, 
  categoryId, 
  repo = 'dacong-wu/astro-blog',      // 默认值
  repoId = 'R_kgDOK1aVGg',            // 默认值
  mapping = 'pathname' 
} = Astro.props;
---

<!-- 🔥 自定义元素容器 -->
<astro-giscus 
  data-category="{category}" 
  data-category-id="{categoryId}"
  data-repo="{repo}"
  data-repo-id="{repoId}"
  data-mapping="{mapping}"
>
  <div class="giscus-container mx-auto px-4 sm:px-6 max-w-3xl pt-8 pb-12"></div>
</astro-giscus>

<script>
  class AstroGiscus extends HTMLElement {
    constructor() {
      super();
      // 延迟一点执行，确保内部 div 已渲染
      requestAnimationFrame(() => this.initializeGiscus());
    }

    initializeGiscus() {
      this.loadGiscusScript();
      this.setupThemeObserver();
    }

    setupThemeObserver() {
      // 🔥 优化：监听 html 标签的 data-theme 属性变化
      // 这比监听特定按钮点击更通用，兼容你的 TopBar/Sidebar 切换逻辑
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.attributeName === 'data-theme') {
            const newTheme = document.documentElement.getAttribute('data-theme');
            if (newTheme) {
              this.updateTheme(newTheme);
            }
          }
        });
      });

      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme']
      });
      
      // 初始化时也同步一次当前主题
      const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
      this.updateTheme(currentTheme);
    }

    updateTheme(theme: string) {
      // 映射主题名称：如果你的 Giscus 主题名叫 'dark' 或 'noborder_dark'，请在此调整
      const giscusTheme = theme === 'dark' ? 'noborder_dark' : 'light';
      
      const iframe = this.shadowRoot?.querySelector('iframe.giscus-frame') || document.querySelector('iframe.giscus-frame');
      if (!iframe || !iframe.contentWindow) return;

      iframe.contentWindow.postMessage(
        { giscus: { setConfig: { theme: giscusTheme } } },
        'https://giscus.app'
      );
      
      console.log(`[Giscus] Theme switched to: ${giscusTheme}`);
    }

    loadGiscusScript() {
      // 防止重复加载
      if (this.querySelector('script[src*="giscus.app/client.js"]')) return;

      const category = this.dataset.category || 'Blog';
      const categoryId = this.dataset.categoryId || '';
      const repo = this.dataset.repo || 'dacong-wu/astro-blog';
      const repoId = this.dataset.repoId || '';
      const mapping = this.dataset.mapping || 'pathname';
      
      // 获取当前主题
      const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
      const giscusTheme = currentTheme === 'dark' ? 'noborder_dark' : 'light';

      const script = document.createElement('script');
      script.src = 'https://giscus.app/client.js';
      script.setAttribute('data-repo', repo);
      script.setAttribute('data-repo-id', repoId);
      script.setAttribute('data-category', category);
      script.setAttribute('data-category-id', categoryId);
      script.setAttribute('data-mapping', mapping);
      script.setAttribute('data-strict', '0');
      script.setAttribute('data-reactions-enabled', '1');
      script.setAttribute('data-emit-metadata', '0');
      script.setAttribute('data-input-position', 'bottom');
      script.setAttribute('data-theme', giscusTheme);
      script.setAttribute('data-lang', 'zh-CN');
      script.setAttribute('crossorigin', 'anonymous');
      script.async = true;

      // 挂载到容器内的 div 中，而不是 head，方便管理
      const container = this.querySelector('.giscus-container');
      if (container) {
        container.appendChild(script);
      } else {
        this.appendChild(script);
      }
    }
  }

  if (!customElements.get('astro-giscus')) {
    customElements.define('astro-giscus', AstroGiscus);
  }
</script>

<style>
  .giscus-container {
    min-height: 200px; /* 防止加载时高度塌陷 */
  }
  /* 可选：添加加载动画 */
  .giscus-container:empty::after {
    content: "加载评论中...";
    display: block;
    text-align: center;
    color: var(--vp-c-text-2);
    padding: 2rem;
  }
</style>