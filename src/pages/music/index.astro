---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="歌单 - zym2013" description="我的音乐收藏">
  <div class="center-wrap project-layout">
    <main class="page-card">
      <header class="d-flex flex-column">
        <h1 id="site-title" class="mb-2">
          歌单<span class="title-subtle">of zym2013</span>
        </h1>
        <nav class="links" aria-label="主要链接"></nav>
      </header>

      <section style="margin-top: 2rem; text-align: center; padding: 3rem 0;">
        <i class="fa-solid fa-music" style="font-size: 3rem; color: var(--muted); margin-bottom: 1rem;"></i>
        <p class="text-muted" style="opacity: 0.8;">歌单页面开发中，敬请期待...</p>
      </section>

      <div class="d-flex justify-content-start mt-4">
        <a href="/" class="back-link">
          <i class="fa-solid fa-arrow-left"></i> 返回首页
        </a>
      </div>
    </main>
  </div>
</Layout>