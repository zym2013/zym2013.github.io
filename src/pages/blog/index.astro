---
import Layout from "../../layouts/Layout.astro";
import PostCard from "../../components/PostCard.astro";
import { getAllPosts } from "../../lib/blog";
import { config } from '../../lib/config';

const allPosts = await getAllPosts({ includeHidden: false });

const blogTitle = config.blog?.authorName;
const blogBio = config.blog?.pageBio;
const siteName = config.site?.name;
---

<Layout title={`博客 - ${siteName}`} description={blogBio} isHome={false}>
  <div class="center-wrap project-layout">
    <main class="page-card blog-list-container">
      <header class="blog-header">
        <h1 id="site-title">
          博客 <span class="title-subtle">of {siteName}</span>
        </h1>
        <p class="blog-desc">{blogBio}</p>
      </header>
      
      <section class="post-grid">
        {
          allPosts.length === 0 ? (
            <div class="empty-state">
              <i class="fa-regular fa-folder-open" />
              <p>暂无文章，敬请期待。</p>
            </div>
          ) : (
            allPosts.map((post, index) => (
              <PostCard
                slug={post.slug}
                title={post.title}
                excerpt={post.description}
                pubDate={post.pubDate}
                wordCount={post.wordCount}
                readingTime={post.readingTime}
                statusConfig={post.statusConfig}
                tags={post.tags}
                icon={post.icon}
                iconColor={post.iconColor}
                category={post.category}
                delay={index * 80}
              />
            ))
          )
        }
      </section>
      
      <div class="back-nav">
        <a href="/" class="back-link">
          <i class="fa-solid fa-arrow-left"></i> 返回首页
        </a>
      </div>
    </main>
  </div>
</Layout>

<style>
  .blog-list-container {
    max-width: 1200px;
    padding: 2rem;
    border: none;
    box-shadow: none;
    background: transparent;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .blog-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--foreground);
  }

  .title-subtle {
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--vp-c-text-3);
    margin-left: 0.5rem;
  }

  .blog-desc {
    color: var(--vp-c-text-2);
    font-size: 1.1rem;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .empty-state {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 0;
    color: var(--vp-c-text-3);
  }

  .empty-state i {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.5;
  }

  .back-nav {
    display: flex;
    justify-content: flex-start;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .back-link {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: gap 0.2s ease;
  }

  .back-link:hover {
    gap: 0.8rem;
  }
  
  @media (max-width: 768px) {
    .blog-list-container {
      padding: 1.5rem 1rem;
    }
    .blog-header h1 {
      font-size: 2rem;
    }
    .post-grid {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
  }
</style>